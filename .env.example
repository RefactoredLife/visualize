# -----------------------------------------------------------------------------
# Visualize configuration
# You can either:
# 1. Copy this file to `.env`, or
# 2. Use the split examples:
#    - `.env.visualize.example`
#    - `.env.google.example`
#    - `.env.mariadb.example`
#    - `.env.mongodb.example`
# Replace every sample value with your own environment-specific settings.
# -----------------------------------------------------------------------------

# Host detection for choosing the finance data root.
# If the current machine hostname matches SERVER_HOSTNAME, VM_FINANCE_PATH is used.
# Otherwise DOCKER_FINANCE_PATH is used.
SERVER_HOSTNAME=your-hostname
VM_FINANCE_PATH=/absolute/path/to/your/finance
DOCKER_FINANCE_PATH=/finance

# -----------------------------------------------------------------------------
# Application / API
# -----------------------------------------------------------------------------
FASTAPI_BASE_URL=http://localhost:8000
MY_API_KEY=replace-with-your-api-key
PW_PEPPER=replace-with-a-long-random-string
OPEN_API_KEY=replace-with-your-openai-api-key
GOOGLE_API_KEY=replace-with-your-google-api-key

# Optional legacy connection string if you still use it anywhere.
db_connection_string=mysql+pymysql://app_user:change_me@localhost:3306/visualize

# -----------------------------------------------------------------------------
# MariaDB
# -----------------------------------------------------------------------------
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DATABASE=visualize
MARIADB_USER=visualize_user
MARIADB_PASSWORD=replace-with-your-mariadb-password

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/visualize

# -----------------------------------------------------------------------------
# Portfolio / account mappings
# Values below are examples only. Update them to match your own account model.
# JSON values must stay on a single line.
# -----------------------------------------------------------------------------
FIDELITY_ACCOUNTS=growth,dividends,roth,rolloverira,utma,hsa,cash
ACCOUNT_NAME_MAPPING={"Unknown":"external_ira"}
ACCOUNT_NUMBER_MAPPING={"external_ira":"Unknown"}
EXTERNAL_ACCOUNTS={"external_asset_1":"off_platform_asset","external_asset_2":"manual_asset"}

# -----------------------------------------------------------------------------
# Google service account credentials
# These must come from your Google Cloud service account JSON.
# Keep GOOGLE_PRIVATE_KEY on one line with literal \n characters.
# -----------------------------------------------------------------------------
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_PRIVATE_KEY_ID=replace-with-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-your-private-key\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=123456789012345678901
GOOGLE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/service-account%40your-project.iam.gserviceaccount.com

# Google Sheets / Apps Script endpoints used by the app.
HOLDINGS_WEB_APP_URL=https://script.google.com/macros/s/your-script-id/exec
HOLDINGS_SHEET_URL=https://docs.google.com/spreadsheets/d/your-holdings-sheet-id/edit
GOOGLE_PORTFOLIO_WORKSHEET=https://docs.google.com/spreadsheets/d/your-portfolio-sheet-id/edit

# -----------------------------------------------------------------------------
# Gmail / IMAP
# -----------------------------------------------------------------------------
GMAIL_USER=you@example.com
GMAIL_PASSWORD=replace-with-your-app-password
GMAIL_IMAP_SERVER=imap.gmail.com
